---
interface Props {
  heading?: string;
  headingHighlight?: string;
  subtext?: string;
  buttonText?: string;
  buttonHref?: string;
  footnote?: string;
}

const {
  heading = "Ready to Stop Doing Work That",
  headingHighlight = "Shouldn't Require a Human?",
  subtext = "Let's talk about your operation. One call. No pitch deck. Just an honest look at where automation actually makes sense for you.",
  buttonText = "Book Your Discovery Call",
  buttonHref = "/contact",
  footnote = "No commitment. No pressure. Just an honest conversation.",
} = Astro.props;
---
<section class="py-28 bg-[#111111] relative overflow-hidden">
  <!-- Lattice background -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: url('/images/lattice-wide.jpg') repeat center / 400px 400px; opacity: 0.04;"
  ></div>
  <!-- Gold glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(201,168,76,0.12) 0%, transparent 70%);"
  ></div>
  <!-- Top border accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/60 to-transparent" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-5xl font-bold text-[#F0F0F0] leading-tight mb-6">
      {heading}<br class="hidden sm:block" />
      <span class="text-[#C9A84C] gold-text">{headingHighlight}</span>
    </h2>
    <p class="text-[#9CA3AF] text-lg md:text-xl leading-relaxed mb-10 max-w-xl mx-auto">
      {subtext}
    </p>
    <a
      href={buttonHref}
      class="inline-block btn-shine btn-gold bg-[#C9A84C] text-[#0A0A0A] font-bold text-lg px-10 py-5 rounded-full hover:bg-[#E2C070] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#111111] transition-colors duration-200 shadow-xl shadow-[#C9A84C]/25"
    >
      {buttonText}
    </a>
    <p class="mt-6 text-[#9CA3AF]/60 text-sm">{footnote}</p>
  </div>
</section>
