---
const year = new Date().getFullYear();
---
<footer class="border-t border-white/5 bg-[#0A0A0A] py-10">
  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    <div>
      <img src="/images/jonroc-logo.png" alt="Jonroc" class="h-8 w-auto mb-1" loading="lazy" />
      <p class="text-[#9CA3AF] text-sm mt-1">&copy; {year} Jonroc LLC. All rights reserved.</p>
    </div>
    <nav aria-label="Social links" class="flex items-center gap-6">
      <a
        href="https://www.linkedin.com/company/jonroc"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#9CA3AF] hover:text-[#C9A84C] text-sm transition-colors duration-200 focus:outline-none focus:underline"
        aria-label="Jonroc on LinkedIn"
      >
        LinkedIn
      </a>
      <a
        href="https://x.com/jonroc"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#9CA3AF] hover:text-[#C9A84C] text-sm transition-colors duration-200 focus:outline-none focus:underline"
        aria-label="Jonroc on X"
      >
        X
      </a>
      <a
        href="https://www.facebook.com/jonroc"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#9CA3AF] hover:text-[#C9A84C] text-sm transition-colors duration-200 focus:outline-none focus:underline"
        aria-label="Jonroc on Facebook"
      >
        Facebook
      </a>
      <a
        href="https://www.youtube.com/@jonroc"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#9CA3AF] hover:text-[#C9A84C] text-sm transition-colors duration-200 focus:outline-none focus:underline"
        aria-label="Jonroc on YouTube"
      >
        YouTube
      </a>
    </nav>
  </div>
</footer>
