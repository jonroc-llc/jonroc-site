---
import { Image } from 'astro:assets';
import benPortrait from '../assets/images/ben-portrait.jpg';
---
<section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-36 pb-20 bg-[#0A0A0A] overflow-hidden">
  <!-- Golden particle wave background -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: url('/images/gold-particle-wave.jpg') center bottom / cover no-repeat; opacity: 0.3;"
  ></div>
  <!-- Dark overlay to keep text readable -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: linear-gradient(to bottom, rgba(10,10,10,0.7) 0%, rgba(10,10,10,0.4) 50%, rgba(10,10,10,0.8) 100%);"
  ></div>

  <div class="relative max-w-6xl mx-auto w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

      <!-- Left: Text content -->
      <div class="flex-1 text-center md:text-left">
        <!-- Label -->
        <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-6 border border-[#C9A84C]/30 rounded-full px-4 py-1">
          AI Agent Installation
        </p>

        <!-- h1 -->
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[#F0F0F0] leading-tight mb-6">
          Your Business Is<br class="hidden sm:block" />
          Bogged Down by<br class="hidden sm:block" />
          <span class="text-[#C9A84C]">Busy Work.</span> Let's Fix That.
        </h1>

        <!-- Subheadline -->
        <p class="text-lg md:text-xl text-[#9CA3AF] max-w-2xl md:mx-0 mx-auto mb-5 leading-relaxed">
          We install AI agents and build marketing systems that handle the work your team shouldn't be doing manually. From operations to online presence, we optimize how your business runs and grows.
        </p>

        <!-- Industry callout -->
        <p class="text-[#C9A84C] font-semibold text-base md:text-lg mb-10">
          Built for construction, rental, and event companies.
        </p>

        <!-- CTA -->
        <a
          id="book-call"
          href="/contact"
          class="inline-block btn-shine bg-[#C9A84C] text-[#0A0A0A] font-bold text-base px-8 py-4 rounded-full hover:bg-[#E2C070] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A0A0A] transition-colors duration-200 shadow-lg shadow-[#C9A84C]/20"
        >
          Book a Free Discovery Call
        </a>
      </div>

      <!-- Right: Benjamin's photo -->
      <div class="flex-shrink-0 flex items-center justify-center">
        <div class="relative">
          <!-- Gold glow behind photo -->
          <div
            class="absolute -inset-4 rounded-3xl opacity-20 blur-2xl pointer-events-none"
            style="background: #C9A84C;"
            aria-hidden="true"
          ></div>
          <Image
            src={benPortrait}
            alt="Benjamin Johnstone, founder of Jonroc"
            width={360}
            height={460}
            format="webp"
            quality={85}
            class="relative w-[260px] md:w-[320px] lg:w-[360px] rounded-2xl border-2 border-[#C9A84C]/40 shadow-2xl shadow-black/60 object-cover"
            loading="eager"
          />
          <!-- Name + title -->
          <div class="relative mt-4 text-center">
            <p class="text-[#F0F0F0] font-semibold text-base">Benjamin Johnstone</p>
            <p class="text-[#C9A84C] text-sm tracking-wide">Owner, Jonroc</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Video placeholder -->
  <div class="relative max-w-4xl w-full mx-auto mt-20">
    <div
      class="w-full aspect-video rounded-2xl border border-white/10 bg-[#111111] flex flex-col items-center justify-center gap-3"
      role="img"
      aria-label="Video placeholder: overview video coming soon"
    >
      <!-- Play icon -->
      <div class="w-16 h-16 rounded-full border-2 border-[#C9A84C]/50 flex items-center justify-center">
        <svg class="w-7 h-7 text-[#C9A84C] ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
      <p class="text-[#9CA3AF] text-sm">Overview video: coming soon</p>
    </div>
    <!-- Subtle glow under video -->
    <div
      class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-3/4 h-8 blur-2xl opacity-30 pointer-events-none"
      style="background: #C9A84C;"
      aria-hidden="true"
    ></div>
  </div>
</section>
