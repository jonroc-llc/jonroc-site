---
---
<section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-20 bg-[#0A0A0A]">
  <!-- Subtle radial glow behind headline -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 80% 50% at 50% 20%, rgba(201,168,76,0.06) 0%, transparent 70%);"
  ></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <!-- Label -->
    <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-6 border border-[#C9A84C]/30 rounded-full px-4 py-1">
      AI Agent Installation
    </p>

    <!-- h1 -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-[#F0F0F0] leading-tight mb-6">
      Your Business Runs on<br class="hidden sm:block" />
      <span class="text-[#C9A84C]">Busy Work.</span> Let's Fix That.
    </h1>

    <!-- Subheadline -->
    <p class="text-lg md:text-xl text-[#9CA3AF] max-w-2xl mx-auto mb-10 leading-relaxed">
      We install AI agents that handle the repetitive stuff your team hates doing. Not a chatbot. Not another app. Actual automation that works inside your existing operation.
    </p>

    <!-- CTA -->
    <a
      id="book-call"
      href="https://calendly.com/jonroc"
      class="inline-block bg-[#C9A84C] text-[#0A0A0A] font-bold text-base px-8 py-4 rounded-full hover:bg-[#E2C070] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A0A0A] transition-colors duration-200 shadow-lg shadow-[#C9A84C]/20"
    >
      Book a Free Discovery Call
    </a>
  </div>

  <!-- Video placeholder -->
  <div class="relative max-w-4xl w-full mx-auto mt-16">
    <div
      class="w-full aspect-video rounded-2xl border border-white/10 bg-[#111111] flex flex-col items-center justify-center gap-3"
      role="img"
      aria-label="Video placeholder — overview video coming soon"
    >
      <!-- Play icon -->
      <div class="w-16 h-16 rounded-full border-2 border-[#C9A84C]/50 flex items-center justify-center">
        <svg class="w-7 h-7 text-[#C9A84C] ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
      <p class="text-[#9CA3AF] text-sm">Overview video — coming soon</p>
    </div>
    <!-- Subtle glow under video -->
    <div
      class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-3/4 h-8 blur-2xl opacity-30 pointer-events-none"
      style="background: #C9A84C;"
      aria-hidden="true"
    ></div>
  </div>
</section>
