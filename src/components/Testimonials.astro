---
const testimonials = [
  {
    quote: "We have used Jonroc Websites and Online Marketing for more than one of our businesses over the past several years. We are pleased with the prompt attention we receive and the cooperative nature of the team. We appreciate receiving educated answers on issues and receiving additional information when we have questions. We have found honesty and trustworthiness are critical when working with vendors in the business arena, especially within facets which we are not skilled or knowledgeable. In that regard we are additionally satisfied with the Jonroc Websites and Online Marketing team.",
    name: "Leann Rodgers",
    company: "Multi-business owner",
    stars: 5,
    source: "Google",
    placeholder: false,
  },
  // PLACEHOLDER: replace with real review
  {
    quote: "[Google review coming]",
    name: "[Reviewer Name]",
    company: "[Business type]",
    stars: 5,
    source: "Google",
    placeholder: true,
  },
  // PLACEHOLDER: replace with real review
  {
    quote: "[Facebook review coming]",
    name: "[Reviewer Name]",
    company: "[Business type]",
    stars: 5,
    source: "Facebook",
    placeholder: true,
  },
];
---

<section class="py-24 bg-[#0A0A0A]">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        What Our Clients Say
      </h2>
      <p class="text-lg text-gray-400">
        Real results from real businesses.
      </p>
    </div>

    <!-- Testimonial Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class={`relative flex flex-col bg-[#111111] border rounded-xl p-8 ${t.placeholder ? 'border-gray-800 opacity-50' : 'border-gray-700'}`}>

          <!-- Opening Quote Mark -->
          <div class="text-[#C9A84C] text-7xl font-serif leading-none mb-4 select-none" aria-hidden="true">
            &ldquo;
          </div>

          <!-- Quote Text -->
          <p class={`flex-1 text-base leading-relaxed mb-6 ${t.placeholder ? 'text-gray-600 italic' : 'text-gray-300'}`}>
            {t.quote}
          </p>

          <!-- Reviewer Info -->
          <div class="mt-auto">
            <!-- Stars -->
            <div class="flex gap-1 mb-3" aria-label={`${t.stars} out of 5 stars`}>
              {Array.from({ length: t.stars }).map(() => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="#C9A84C"
                  class="w-5 h-5"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.163c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.175 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.062 9.384c-.783-.57-.38-1.81.588-1.81h4.163a1 1 0 00.951-.69L9.049 2.927z" />
                </svg>
              ))}
            </div>

            <!-- Name + Company -->
            <p class="text-white font-bold text-sm">{t.name}</p>
            <p class="text-gray-500 text-sm mb-4">{t.company}</p>

            <!-- Source Badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-gray-700 text-xs text-gray-400">
              {t.source === "Google" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-3.5 h-3.5" aria-hidden="true">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
              )}
              {t.source === "Facebook" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-3.5 h-3.5" aria-hidden="true">
                  <path fill="#1877F2" d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.269h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
                </svg>
              )}
              <span>{t.source}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
