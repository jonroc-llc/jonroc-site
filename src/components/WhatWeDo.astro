---
const features = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`,
    title: "Document Processing",
    body: "Contracts, RFIs, invoices, safety forms. Agents read them, extract what matters, file them where they go, and flag anything that needs a human.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`,
    title: "Scheduling & Dispatching",
    body: "Jobs get assigned based on crew availability, location, and equipment. Changes get communicated automatically. No more back-and-forth in group texts.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>`,
    title: "Customer Communication",
    body: "Quotes go out fast. Follow-ups happen on schedule. Questions get answered at 11pm without anyone staying late.",
  },
];
---
<section class="py-24 bg-[#0A0A0A]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-3xl mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] mb-6">What We Do</h2>
      <p class="text-[#9CA3AF] text-lg leading-relaxed">
        We build and install AI agents directly into your business. These are software programs that run on your systems, connect to your existing tools, and handle specific tasks automatically — without you touching them.
      </p>
      <p class="text-[#9CA3AF] text-lg leading-relaxed mt-4">
        This is not a chatbot on your website. This is not another SaaS platform you'll forget to cancel. This is custom automation, installed for your operation, running in the background while your team focuses on actual work.
      </p>
    </div>

    <h3 class="text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-8">What agents actually handle</h3>

    <div class="grid md:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="bg-[#111111] border border-white/5 rounded-2xl p-8 hover:border-[#C9A84C]/30 transition-colors duration-300">
          <div class="text-[#C9A84C] mb-4" set:html={f.icon} />
          <h3 class="text-[#F0F0F0] font-semibold text-lg mb-3">{f.title}</h3>
          <p class="text-[#9CA3AF] leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
