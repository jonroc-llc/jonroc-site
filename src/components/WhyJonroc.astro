---
const pillars = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "15 years of building things that work.",
    body: "Jonroc has been in business since 2011. We've built websites, marketing systems, and automation for companies across industries. We've seen what works and what just looks good in a demo.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: "Your data stays yours.",
    body: "We build on open source tools wherever possible. That means no vendor lock-in, no platform risk, and no one else monetizing your business data. When we install something, you own it.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "Pick what you need. Skip what you don't.",
    body: "This is not a bundle. You don't pay for features you'll never use. We identify the highest-value problems in your operation and start there. You can expand later or keep it focused. Your call.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
    title: "No subscription required.",
    body: "Most of what we build is a one-time installation, not a recurring license. You pay for the work, not for the privilege of keeping it running. Some agents do have hosting costs, and we'll be upfront about exactly what those are before you commit to anything.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    title: "Operations AND marketing.",
    body: "We don't just automate your back office. We build and manage your entire digital presence too. Website, ad campaigns, SEO, social media. One partner handling both sides of the business means everything works together instead of pulling in different directions.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
    title: "AI agent safety, managed for you.",
    body: "AI agentic systems are powerful, and yes, they come with real risks that need to be managed. We don't gloss over that. We identify the specific safety concerns relevant to your business, put the right guardrails in place, and make sure you can use this technology confidently. Waiting until every risk is eliminated isn't a strategy. If your competitors start now and you wait two years, they won't just be ahead of you. They could be five or six years ahead. We help you move fast without moving recklessly.",
  },
];
---
<section class="py-24 bg-[#111111] relative overflow-hidden">
  <!-- Tight lattice background pattern -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: url('/images/lattice-tight.jpg') repeat center / 300px 300px; opacity: 0.02;"
  ></div>
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] mb-4">Why Jonroc</h2>
    <p class="text-[#9CA3AF] text-lg mb-14 max-w-xl">
      What makes us different from the other AI companies flooding your inbox.
    </p>

    <div class="grid sm:grid-cols-2 gap-6">
      {pillars.map((p) => (
        <div class="border border-white/8 rounded-2xl p-8 hover:border-[#C9A84C]/20 transition-colors duration-300" style="background-color: #060606;">
          <div class="text-[#C9A84C] mb-4" set:html={p.icon} />
          <h3 class="text-[#F0F0F0] font-bold text-lg mb-3">{p.title}</h3>
          <p class="text-[#9CA3AF] leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
