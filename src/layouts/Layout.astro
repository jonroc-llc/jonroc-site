---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Jonroc: AI Agent Installation for Growing Businesses" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title} | Jonroc</title>

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Jonroc`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Jonroc" />
  </head>
  <body class="min-h-screen bg-[#0A0A0A] text-[#F0F0F0] antialiased">
    <!-- Skip to main content for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-[#C9A84C] focus:text-[#0A0A0A] focus:font-semibold focus:px-4 focus:py-2 focus:rounded-full focus:outline-none"
    >
      Skip to main content
    </a>

    <slot />

    <!-- Gold text: fire shine animation on scroll entry -->
    <script>
      function initGoldText() {
        const els = document.querySelectorAll('.gold-text');
        if (!els.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                setTimeout(() => {
                  entry.target.classList.add('gold-active');
                  // Unobserve after firing — one-shot only
                  observer.unobserve(entry.target);
                }, 80);
              }
            });
          },
          { threshold: 0.2 }
        );

        els.forEach((el) => observer.observe(el));
      }

      // Run on initial load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initGoldText);
      } else {
        initGoldText();
      }
    </script>
  </body>
</html>
