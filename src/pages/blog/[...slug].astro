---
import { getCollection, getEntry } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title={post.data.title} description={post.data.description}>
  <Header />
  <main id="main-content" class="pt-24 pb-20 bg-[#0A0A0A] min-h-screen">
    <div class="max-w-3xl mx-auto px-6 py-12">

      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-[#9CA3AF] hover:text-[#C9A84C] transition-colors duration-200 mb-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>

      <!-- Post header -->
      <header class="mb-10">
        <!-- Tags -->
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-5">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs font-medium text-[#C9A84C] bg-[#C9A84C]/10 px-2.5 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Title -->
        <h1 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] leading-tight mb-5">
          {post.data.title}
        </h1>

        <!-- Author + Date -->
        <div class="flex items-center gap-3 text-sm text-[#9CA3AF]">
          <div class="w-8 h-8 rounded-full bg-[#C9A84C]/20 flex items-center justify-center text-[#C9A84C] font-bold text-xs">
            B
          </div>
          <div>
            <span class="text-[#F0F0F0] font-medium">{post.data.author}</span>
            <span class="mx-2 text-white/20">|</span>
            <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
          </div>
        </div>
      </header>

      <!-- Divider -->
      <div class="border-t border-white/5 mb-10"></div>

      <!-- Post body -->
      <article class="prose prose-invert prose-jonroc max-w-none">
        <Content />
      </article>

      <!-- Divider -->
      <div class="border-t border-white/5 mt-16 mb-10"></div>

      <!-- CTA -->
      <section class="bg-[#111111] border border-[#C9A84C]/20 rounded-2xl p-8 text-center">
        <p class="text-[#9CA3AF] text-sm uppercase tracking-widest font-semibold mb-3">Take the Next Step</p>
        <h2 class="text-2xl md:text-3xl font-bold text-[#F0F0F0] mb-4">
          Ready to put agents to work in your business?
        </h2>
        <p class="text-[#9CA3AF] mb-8 max-w-md mx-auto">
          We install, configure, and manage AI agents for growing businesses. No fluff. Just results.
        </p>
        <a
          href="/contact"
          class="inline-block btn-shine bg-[#C9A84C] text-[#0A0A0A] font-semibold px-8 py-3.5 rounded-full hover:bg-[#E2C070] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A0A0A] transition-colors duration-200"
        >
          Book a Discovery Call
        </a>
      </section>

    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* Dark-theme prose customization */
  .prose-jonroc {
    --tw-prose-body: #D1D5DB;
    --tw-prose-headings: #F0F0F0;
    --tw-prose-lead: #9CA3AF;
    --tw-prose-links: #C9A84C;
    --tw-prose-bold: #F0F0F0;
    --tw-prose-counters: #9CA3AF;
    --tw-prose-bullets: #C9A84C;
    --tw-prose-hr: rgba(255,255,255,0.1);
    --tw-prose-quotes: #F0F0F0;
    --tw-prose-quote-borders: #C9A84C;
    --tw-prose-captions: #9CA3AF;
    --tw-prose-code: #C9A84C;
    --tw-prose-pre-code: #F0F0F0;
    --tw-prose-pre-bg: #111111;
    --tw-prose-th-borders: rgba(255,255,255,0.1);
    --tw-prose-td-borders: rgba(255,255,255,0.05);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .prose-jonroc h1,
  .prose-jonroc h2,
  .prose-jonroc h3,
  .prose-jonroc h4 {
    color: #F0F0F0;
    font-weight: 700;
  }

  .prose-jonroc h2 {
    color: #C9A84C;
    border-bottom: 1px solid rgba(201,168,76,0.2);
    padding-bottom: 0.4em;
    margin-top: 2.5em;
  }

  .prose-jonroc a {
    color: #C9A84C;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-jonroc a:hover {
    color: #E2C070;
  }

  .prose-jonroc strong {
    color: #F0F0F0;
  }

  .prose-jonroc blockquote {
    border-left-color: #C9A84C;
    background: rgba(201,168,76,0.05);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.75rem 1.25rem;
    color: #D1D5DB;
    font-style: normal;
  }

  .prose-jonroc code {
    background: rgba(201,168,76,0.1);
    color: #C9A84C;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .prose-jonroc hr {
    border-color: rgba(255,255,255,0.1);
    margin: 2.5rem 0;
  }

  .prose-jonroc ul li::marker {
    color: #C9A84C;
  }

  .prose-jonroc ol li::marker {
    color: #9CA3AF;
  }
</style>
