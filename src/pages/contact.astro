---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Contact"
  description="Book a free 15-minute discovery call with Benjamin at Jonroc. Let's talk about your business operations and where AI agents can make the biggest difference."
>
  <Header />

  <main id="main-content">

    <!-- Hero -->
    <section class="relative flex flex-col items-center justify-center px-6 pt-36 pb-20 bg-[#0A0A0A]">
      <!-- Radial glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 70% 50% at 50% 20%, rgba(201,168,76,0.06) 0%, transparent 70%);"
      ></div>

      <div class="relative max-w-3xl mx-auto text-center">
        <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-6 border border-[#C9A84C]/30 rounded-full px-4 py-1">
          Get in Touch
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-[#F0F0F0] leading-tight mb-6">
          Let's Talk About<br class="hidden sm:block" />
          <span class="text-[#C9A84C] gold-text">Your Business</span>
        </h1>
        <p class="text-lg md:text-xl text-[#9CA3AF] max-w-2xl mx-auto leading-relaxed">
          Pick a time that works for you. It's a straight conversation, no pressure, no sales script. Just an honest look at what's slowing your team down.
        </p>
      </div>
    </section>

    <!-- Quick Nav Buttons -->
    <section class="py-10 bg-[#0A0A0A]">
      <div class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-center gap-4">

        <!-- Book a Meeting -->
        <a
          href="#booking"
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full bg-[#C9A84C] text-[#0A0A0A] font-bold text-base hover:bg-[#E2C070] transition-colors duration-200 w-full sm:w-auto text-center"
        >
          Book a Meeting
        </a>

        <!-- Contact Us -->
        <a
          href="#contact-form"
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full border border-[#C9A84C] text-[#C9A84C] font-bold text-base bg-transparent hover:bg-[#C9A84C]/10 transition-colors duration-200 w-full sm:w-auto text-center"
        >
          Contact Us
        </a>

        <!-- Phone -->
        <a
          href="tel:+18022143818"
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full border border-[#C9A84C] text-[#C9A84C] font-bold text-base bg-transparent hover:bg-[#C9A84C]/10 transition-colors duration-200 w-full sm:w-auto text-center"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          802-214-3818
        </a>

      </div>
    </section>

    <!-- Booking Embed -->
    <section class="py-16 bg-[#0A0A0A]">
      <div id="booking" class="max-w-4xl mx-auto px-6">

        <!-- Card wrapper -->
        <div class="rounded-2xl border border-white/8 bg-[#111111] overflow-hidden shadow-2xl shadow-black/50">
          <!-- Card header -->
          <div class="px-8 py-6 border-b border-white/5 flex items-center gap-3">
            <div class="w-2 h-2 rounded-full bg-[#C9A84C]" aria-hidden="true"></div>
            <p class="text-[#F0F0F0] font-semibold">Book a 15-Minute Discovery Call with Benjamin</p>
          </div>

          <!-- GHL Booking iframe -->
          <div class="p-4 md:p-8">
            <iframe
              src="https://gowith.jonroc.com/widget/bookings/15-with-benjamin"
              style="width:100%;border:none;overflow:hidden;min-height:700px;"
              scrolling="no"
              id="ghl-booking"
              title="Book a discovery call with Benjamin"
              loading="lazy"
            ></iframe>
          </div>
        </div>

      </div>
    </section>

    <!-- Contact Form -->
    <section class="py-24 bg-[#0A0A0A]">
      <div id="contact-form" class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-5 border border-[#C9A84C]/30 rounded-full px-4 py-1">
            Send a Message
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] leading-tight">
            Prefer to <span class="text-[#C9A84C] gold-text">Write It Out?</span>
          </h2>
          <p class="text-[#9CA3AF] mt-4 leading-relaxed">Fill out the form below and Benjamin will get back to you shortly.</p>
        </div>

        <form
          action="https://hooks.zapier.com/placeholder"
          method="POST"
          class="bg-[#111111] border border-white/5 rounded-2xl p-8 md:p-10 space-y-6 shadow-2xl shadow-black/40"
        >
          <!-- Name -->
          <div>
            <label for="contact-name" class="block text-[#F0F0F0] text-sm font-semibold mb-2">
              Name <span class="text-[#C9A84C]" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              placeholder="Your full name"
              class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-[#F0F0F0] placeholder-[#9CA3AF]/50 focus:outline-none focus:border-[#C9A84C]/60 focus:ring-1 focus:ring-[#C9A84C]/40 transition-colors duration-200"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="contact-email" class="block text-[#F0F0F0] text-sm font-semibold mb-2">
              Email <span class="text-[#C9A84C]" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              placeholder="you@yourcompany.com"
              class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-[#F0F0F0] placeholder-[#9CA3AF]/50 focus:outline-none focus:border-[#C9A84C]/60 focus:ring-1 focus:ring-[#C9A84C]/40 transition-colors duration-200"
            />
          </div>

          <!-- Phone (optional) -->
          <div>
            <label for="contact-phone" class="block text-[#F0F0F0] text-sm font-semibold mb-2">
              Phone <span class="text-[#9CA3AF] font-normal text-xs">(optional)</span>
            </label>
            <input
              type="tel"
              id="contact-phone"
              name="phone"
              placeholder="(555) 000-0000"
              class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-[#F0F0F0] placeholder-[#9CA3AF]/50 focus:outline-none focus:border-[#C9A84C]/60 focus:ring-1 focus:ring-[#C9A84C]/40 transition-colors duration-200"
            />
          </div>

          <!-- Message -->
          <div>
            <label for="contact-message" class="block text-[#F0F0F0] text-sm font-semibold mb-2">
              Message <span class="text-[#C9A84C]" aria-hidden="true">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              placeholder="Tell us a bit about your business and what you're trying to fix."
              class="w-full bg-[#1A1A1A] border border-white/10 rounded-xl px-4 py-3 text-[#F0F0F0] placeholder-[#9CA3AF]/50 focus:outline-none focus:border-[#C9A84C]/60 focus:ring-1 focus:ring-[#C9A84C]/40 transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <div>
            <button
              type="submit"
              class="w-full bg-[#C9A84C] text-[#0A0A0A] font-bold text-base px-8 py-4 rounded-full hover:bg-[#E2C070] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#111111] transition-colors duration-200"
            >
              Send Message
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="py-24 bg-[#111111] relative overflow-hidden">
      <!-- Top border accent -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/60 to-transparent" aria-hidden="true"></div>

      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-5 border border-[#C9A84C]/30 rounded-full px-4 py-1">
            What to Expect
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] leading-tight">
            Three Steps. No&nbsp;<span class="text-[#C9A84C] gold-text">Fluff.</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

          <!-- Step 1 -->
          <div class="relative">
            <div class="w-12 h-12 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/30 flex items-center justify-center mb-6">
              <span class="text-[#C9A84C] font-bold text-lg">1</span>
            </div>
            <!-- Connector line (hidden on mobile) -->
            <div class="hidden md:block absolute top-6 left-12 right-0 h-px bg-gradient-to-r from-[#C9A84C]/20 to-transparent" aria-hidden="true"></div>
            <h3 class="text-[#F0F0F0] font-semibold text-xl mb-3">Book a Call</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              Pick a 15-minute slot that works for you using the calendar above. It's quick, easy, and free.
            </p>
          </div>

          <!-- Step 2 -->
          <div class="relative">
            <div class="w-12 h-12 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/30 flex items-center justify-center mb-6">
              <span class="text-[#C9A84C] font-bold text-lg">2</span>
            </div>
            <div class="hidden md:block absolute top-6 left-12 right-0 h-px bg-gradient-to-r from-[#C9A84C]/20 to-transparent" aria-hidden="true"></div>
            <h3 class="text-[#F0F0F0] font-semibold text-xl mb-3">We Dig Into Your Operation</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              Benjamin will ask real questions about how your team works. What's repetitive, what's expensive, and where the bottlenecks are.
            </p>
          </div>

          <!-- Step 3 -->
          <div>
            <div class="w-12 h-12 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/30 flex items-center justify-center mb-6">
              <span class="text-[#C9A84C] font-bold text-lg">3</span>
            </div>
            <h3 class="text-[#F0F0F0] font-semibold text-xl mb-3">You Get a Custom Proposal</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              If there's a fit, Benjamin will put together a proposal specific to your operation: what to automate, how it works, and what it costs.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Location info only (no exposed email) -->
    <section class="py-24 bg-[#111111] relative overflow-hidden">
      <!-- Lattice background -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: url('/images/lattice-wide.jpg') repeat center / 400px 400px; opacity: 0.04;"
      ></div>
      <!-- Background glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(201,168,76,0.12) 0%, transparent 70%);"
      ></div>
      <!-- Top border accent -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/60 to-transparent" aria-hidden="true"></div>
      <div class="max-w-5xl mx-auto px-6 relative">
        <div class="text-center mb-14">
          <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-5 border border-[#C9A84C]/30 rounded-full px-4 py-1">
            Based In
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] leading-tight">
            Richmond, VA. <span class="text-[#C9A84C] gold-text">Serving Nationwide.</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">

          <!-- Phone -->
          <div class="bg-[#111111] rounded-xl border border-white/5 p-7 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <div>
              <p class="text-[#9CA3AF] text-xs font-semibold tracking-widest uppercase mb-1">Phone</p>
              <a href="tel:+18042143818" class="text-[#F0F0F0] font-medium hover:text-[#C9A84C] transition-colors duration-200">(804) 214-3818</a>
            </div>
          </div>

          <!-- Location -->
          <div class="bg-[#111111] rounded-xl border border-white/5 p-7 flex flex-col gap-4">
            <div class="w-11 h-11 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[#9CA3AF] text-xs font-semibold tracking-widest uppercase mb-1">Location</p>
              <p class="text-[#F0F0F0] font-medium">Richmond, VA</p>
              <p class="text-[#9CA3AF] text-sm mt-0.5">Serving clients nationwide</p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
