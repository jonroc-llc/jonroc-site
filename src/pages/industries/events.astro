---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
---
<Layout
  title="AI Agents and Digital Marketing for Event Companies"
  description="Jonroc builds AI agents and runs digital marketing for venues, caterers, and event planners. Automated inquiry responses, client communication, and local SEO that turns browsers into booked clients."
>
  <Header />

  <main id="main-content">

    <!-- Hero -->
    <section class="relative min-h-[70vh] flex flex-col items-center justify-center px-6 pt-36 pb-24 bg-[#0A0A0A]">
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 70% 50% at 50% 30%, rgba(201,168,76,0.07) 0%, transparent 70%);"
      ></div>

      <div class="relative max-w-4xl mx-auto text-center">
        <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-6 border border-[#C9A84C]/30 rounded-full px-4 py-1">
          Events Industry
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-[#F0F0F0] leading-tight mb-8">
          AI Agents and Digital Marketing<br class="hidden md:block" />
          for <span class="text-[#C9A84C] gold-text">Event Companies</span>
        </h1>
        <p class="text-lg md:text-xl text-[#9CA3AF] max-w-2xl mx-auto leading-relaxed mb-6">
          Venues, caterers, event planners. Your business runs on logistics, relationships, and a calendar that can never be wrong.
        </p>
        <p class="text-lg md:text-xl text-[#9CA3AF] max-w-2xl mx-auto leading-relaxed mb-12">
          Jonroc installs the AI agents that handle the operational overhead and builds the digital presence that converts browsers into booked clients before they ever pick up the phone.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-block btn-shine btn-gold bg-[#C9A84C] text-[#0A0A0A] font-bold text-base px-10 py-5 rounded-full hover:bg-[#E2C070] focus:outline-none focus:ring-2 focus:ring-[#C9A84C] focus:ring-offset-2 focus:ring-offset-[#0A0A0A] transition-colors duration-200"
          >
            Book a Free Discovery Call
          </a>
          <a
            href="#what-we-do"
            class="inline-block border border-white/20 text-[#F0F0F0] font-semibold text-base px-10 py-5 rounded-full hover:border-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition-colors duration-200"
          >
            See What We Do
          </a>
        </div>
      </div>
    </section>

    <!-- Pain Points -->
    <section class="py-24 bg-[#111111] relative">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/40 to-transparent" aria-hidden="true"></div>
      <div class="max-w-6xl mx-auto px-6">
        <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-5 border border-[#C9A84C]/30 rounded-full px-4 py-1">
          The Real Problems
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] mb-4 leading-tight">
          What's Costing You Clients
        </h2>
        <p class="text-[#9CA3AF] text-lg mb-14 max-w-2xl leading-relaxed">
          Event businesses deal with complex logistics, high client expectations, and deadlines that can't move. Here's where things tend to break.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <!-- Pain Point 1 -->
          <div class="bg-[#1A1A1A] border border-white/5 rounded-2xl p-8 hover:border-[#C9A84C]/20 transition-colors duration-300">
            <div class="w-10 h-10 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">Inquiry Response Time Losing Bookings</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              A couple submits an inquiry Friday evening. You get back to them Monday. They booked a venue Saturday afternoon. In the events industry, the first to respond with confidence and clarity wins. Slow response time is a direct revenue loss.
            </p>
          </div>

          <!-- Pain Point 2 -->
          <div class="bg-[#1A1A1A] border border-white/5 rounded-2xl p-8 hover:border-[#C9A84C]/20 transition-colors duration-300">
            <div class="w-10 h-10 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">Event Logistics Communication Chaos</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              Coordinating vendors, timelines, staff assignments, and client expectations across text threads and spreadsheets. Something always falls through the cracks. Usually right before the event, when there's no room for it.
            </p>
          </div>

          <!-- Pain Point 3 -->
          <div class="bg-[#1A1A1A] border border-white/5 rounded-2xl p-8 hover:border-[#C9A84C]/20 transition-colors duration-300">
            <div class="w-10 h-10 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">Online Presence Not Converting Browsers to Booked Clients</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              Couples and corporate clients do extensive research before they reach out. If your website doesn't inspire confidence, answer their key questions, and make booking feel easy, they move on to someone whose site does.
            </p>
          </div>

          <!-- Pain Point 4 -->
          <div class="bg-[#1A1A1A] border border-white/5 rounded-2xl p-8 hover:border-[#C9A84C]/20 transition-colors duration-300">
            <div class="w-10 h-10 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">No Time to Manage Social Media and Marketing</h3>
            <p class="text-[#9CA3AF] leading-relaxed">
              You're executing events, managing clients, coordinating vendors. Marketing gets pushed to "when things slow down." Things never slow down. Jonroc handles execution so your marketing actually happens.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Do -->
    <section id="what-we-do" class="py-24 bg-[#0A0A0A] relative">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/40 to-transparent" aria-hidden="true"></div>
      <div class="max-w-6xl mx-auto px-6">
        <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-5 border border-[#C9A84C]/30 rounded-full px-4 py-1">
          What We Do
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-[#F0F0F0] mb-4 leading-tight">
          What Jonroc Does for<br class="hidden sm:block" />
          <span class="text-[#C9A84C] gold-text">Event Companies</span>
        </h2>
        <p class="text-[#9CA3AF] text-lg mb-14 max-w-2xl leading-relaxed">
          Automation that handles the communication overhead, and a digital presence that does the selling before you ever get on a call.
        </p>

        <div class="grid md:grid-cols-2 gap-10">
          <!-- AI Agents -->
          <div>
            <h3 class="text-lg font-bold text-[#C9A84C] mb-6 flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
              </span>
              AI Agents
            </h3>
            <ul class="space-y-4">
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Automated inquiry responses.</span>
                  <span class="text-[#9CA3AF]"> Agents respond to new inquiries immediately with personalized information, availability, and next steps.</span>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Client communication agents.</span>
                  <span class="text-[#9CA3AF]"> Every client wants updates. Agents send them automatically so your team isn't repeating the same answers all day.</span>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Booking and contract admin.</span>
                  <span class="text-[#9CA3AF]"> Intake forms, contracts, deposits, signed documents. Agents collect it all, file it, and flag anything missing.</span>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Vendor coordination.</span>
                  <span class="text-[#9CA3AF]"> Chasing confirmations, keeping timelines updated, making sure every vendor has the right info. Agents handle the back-and-forth.</span>
                </div>
              </li>
            </ul>
          </div>

          <!-- Digital Marketing -->
          <div>
            <h3 class="text-lg font-bold text-[#C9A84C] mb-6 flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-[#C9A84C]/10 border border-[#C9A84C]/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-[#C9A84C]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061A1.125 1.125 0 0 1 3 16.811V8.69ZM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 0 1 0 1.954l-7.108 4.061a1.125 1.125 0 0 1-1.683-.977V8.69Z" />
                </svg>
              </span>
              Digital Marketing
            </h3>
            <ul class="space-y-4">
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Venue and catering website design.</span>
                  <span class="text-[#9CA3AF]"> Sites that showcase your work, answer client questions, and make it easy to take the next step.</span>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Local SEO.</span>
                  <span class="text-[#9CA3AF]"> Show up when couples and corporate planners search for venues, caterers, and event services in your market.</span>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Social media management.</span>
                  <span class="text-[#9CA3AF]"> Consistent, professional presence across platforms. We handle the content so you can handle the events.</span>
                </div>
              </li>
              <li class="flex gap-3">
                <span class="text-[#C9A84C] mt-1 flex-shrink-0" aria-hidden="true">&#x25B8;</span>
                <div>
                  <span class="text-[#F0F0F0] font-semibold">Execution, not just strategy.</span>
                  <span class="text-[#9CA3AF]"> We build it, run it, and keep it working. Your marketing actually happens.</span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- The Stakes -->
    <section class="py-24 bg-[#111111] relative overflow-hidden">
      <div
        class="absolute inset-0 pointer-events-none"
        aria-hidden="true"
        style="background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);"
      ></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/40 to-transparent" aria-hidden="true"></div>

      <div class="relative max-w-3xl mx-auto px-6 text-center">
        <p class="inline-block text-[#C9A84C] text-sm font-semibold tracking-widest uppercase mb-6 border border-[#C9A84C]/30 rounded-full px-4 py-1">
          The Stakes
        </p>
        <blockquote class="text-2xl md:text-3xl text-[#F0F0F0] font-bold leading-tight mb-6">
          "In the events industry, first impressions are everything. Your website and your response time are your first impression. We make both work for you."
        </blockquote>
        <p class="text-[#9CA3AF] text-lg leading-relaxed">
          Clients decide within minutes whether they're going to reach out. If your website doesn't do its job and your response doesn't come fast, they move on to someone whose does.
        </p>
      </div>
    </section>
    <!-- CTA -->
    <CTASection
      heading="Ready to Convert More"
      headingHighlight="Inquiries Into Bookings?"
      subtext="One call. No pitch deck. Let's look at your inquiry process and your online presence together."
      buttonText="Book a Free Discovery Call"
      footnote="No commitment. No pressure."
    />

  </main>

  <Footer />
</Layout>
